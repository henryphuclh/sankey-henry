OPENAI_API_KEY=sk-YOUR_KEY_HERE

# Optional: override model names
# OPENAI_MODEL_EXTRACTION=gpt-4o-mini
# OPENAI_MODEL_FALLBACK=gpt-4o
# OPENAI_MODEL_SIMPLE=gpt-4o-mini

# ── SEC EDGAR ─────────────────────────────────────────────────────────────────
SEC_USER_AGENT=YourName YourEmail@example.com
